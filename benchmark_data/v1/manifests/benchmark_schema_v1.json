{
  "schema_version": "v1",
  "required_fields": [
    "sample_id",
    "expert_target",
    "source_type",
    "source_path",
    "input",
    "provisional_gold",
    "tags"
  ],
  "field_specs": {
    "sample_id": "string unique id",
    "expert_target": "e1|e2|e3|council",
    "source_type": "string",
    "source_path": "relative source path",
    "input": {
      "agent_id": "string",
      "system_name": "string",
      "system_description": "string"
    },
    "provisional_gold": {
      "recommendation": "APPROVE|REVIEW|REJECT|null",
      "risk_tier": "string|null",
      "human_review_required": "boolean",
      "citations": "string[]",
      "must_hit_findings": "string[]",
      "provenance": "string"
    },
    "tags": "string[]",
    "split": "dev|test (optional in raw candidates)"
  }
}

