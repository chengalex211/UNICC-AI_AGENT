# ── real_frontend environment variables ────────────────────────────────────────
# Copy to .env.local and fill in values. All variables are optional;
# defaults shown here are the same defaults used in the source code.

# Base URL of the frontend_api (FastAPI) server
# Default: http://localhost:8100
VITE_API_URL=http://localhost:8100

# ── Council LLM backend ─────────────────────────────────────────────────────────
# Which LLM backend the Council pipeline uses.
# Accepted values: claude | vllm
# Default: claude
VITE_COUNCIL_BACKEND=claude

# vLLM / SLM server — only used when VITE_COUNCIL_BACKEND=vllm
# The URL must be reachable from the machine running frontend_api, not the browser.
VITE_VLLM_BASE_URL=http://127.0.0.1:8000
VITE_VLLM_MODEL=meta-llama/Meta-Llama-3-70B-Instruct
