# UNICC Council — environment variables
# Copy this file to expert3_rag/env and fill in your values
# The backend auto-detects available LLM (vLLM first, Claude fallback)

# Option A: Claude API (cloud, no GPU needed)
ANTHROPIC_API_KEY=sk-ant-...

# Option B: vLLM local server (DGX, no API key needed)
# Start vLLM first: vllm serve meta-llama/Meta-Llama-3.1-70B-Instruct --port 8000
# Then start this backend: bash start.sh
# VLLM_BASE_URL=http://localhost:8000
