# Copy this file to .env and fill in your API keys before starting the server.
#
#   cp Expert1/.env.example Expert1/.env
#
# The server loads this file automatically on startup:
#   cd frontend_api && source Expert1/.env && uvicorn main:app --host 0.0.0.0 --port 8100

# Required — Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed if evaluating systems that use OpenAI internally
OPENAI_API_KEY=sk-proj-...

# Optional — set to 1 to enable live adversarial attack mode in Expert 1.
# Default is off. The target system must be running and accessible at live_target_url.
UNICC_LIVE_ATTACK_ENABLED=0
